---
export const prerender = true;
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { sanityClient } from '~/sanity/client';

const service = await sanityClient.fetch(
  `*[_type == "service" && slug.current == "digital-presence"][0]`
);

const metadata = {
  title: `${service.title} — Producentric`,
};
---

<Layout {metadata}>

  <HeroText
    tagline="What We Do"
    title={service.title}
    subtitle={service.subtitle}
  />

  <Features
    title="What this looks like in practice"
    columns={2}
    classes={{ container: 'py-6 md:py-8 lg:py-10' }}
    items={service.capabilities.map((cap: any) => ({
      title: cap.title,
      description: cap.description,
      icon: cap.icon,
    }))}
  />

  <CallToAction
    classes={{ container: 'py-6 md:py-8 lg:py-10' }}
    actions={[
      {
        variant: 'primary',
        text: 'Get in touch',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">{service.ctaTitle}</Fragment>
    <Fragment slot="subtitle">{service.ctaSubtitle}</Fragment>
  </CallToAction>

</Layout>