---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Producentric - Product thinking. Process discipline. Real results.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
actions={[
  {
    variant: 'primary',
    text: 'Get in touch',
    href: '/contact',
    classes: 'px-8 py-4 text-lg',
  },
]}
>
  <Fragment slot="title">
    Strategy and execution for teams that need to
    <span class="text-accent dark:text-white"> move faster</span>
  </Fragment>

  <Fragment slot="subtitle">
    Producentric is a boutique consulting firm helping organizations improve
    their products, processes, and operations.
  </Fragment>
</Hero>

<Features
  id="features"
  title="What we do"
  subtitle="We work across three core areas to help organizations move faster, operate better, and deliver with confidence."
  columns={3}
  classes={{ container: 'py-6 md:py-8 lg:py-10' }}
  items={[
    {
      title: 'Product Management',
      description:
        'We bring product thinking to teams that need direction and momentum. From discovery and ideation through to customer validation, we help you build the right things; and confirm they are working.',
      icon: 'tabler:bulb',
    },
    {
      title: 'Project Management',
      description:
        'We keep complex initiatives on track. Clear ownership, realistic timelines, and the discipline to deliver on scope, on budget, and on schedule.',
      icon: 'tabler:checklist',
    },
    {
      title: 'Process Improvement',
      description:
        'We streamline how your organization works; from compact projects to large corporate programs. Whether you need leaner workflows or a scalable agile framework like SAFe, we meet you where you are.',
      icon: 'tabler:settings',
    },
  ]}
/>

  <!-- Steps Widget ****************** -->

<Steps
  title="How we work"
  classes={{ container: 'py-6 md:py-8 lg:py-10' }}
  items={[
    {
      title: 'Step 1: <span class="font-medium">Understand</span>',
      description:
        "We don't parachute in with ready-made answers. We take the time to deeply understand your reality; your constraints, your team, and the root cause of the problem. Your challenges become ours.",
      icon: 'tabler:ear',
    },
    {
      title: 'Step 2: <span class="font-medium">Define</span>',
      description:
        'We turn that understanding into a clear, actionable plan built around your specific context; not a generic playbook.',
      icon: 'tabler:map',
    },
    {
      title: 'Step 3: <span class="font-medium">Execute</span>',
      description:
        'We work alongside your team, not above it. Real involvement, real accountability, until the work is done.',
      icon: 'tabler:rocket',
    },
    {
      title: 'Step 4: <span class="font-medium">Validate</span>',
      description:
        'Delivery is not the finish line. We stay involved to measure outcomes, gather feedback, and make sure what we built is actually working.',
      icon: 'tabler:check',
    },
  ]}
  image={{
    src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=987&q=80',
    alt: 'Team working together',
  }}
/>

<CallToAction
  classes={{ container: 'py-6 md:py-8 lg:py-10' }}
  actions={[
    {
      variant: 'primary',
      text: 'Contact Producentric',
      href: '/contact',
    },
  ]}
>
  <Fragment slot="title">
    Ready to work with us?
  </Fragment>

  <Fragment slot="subtitle">
    We'd love to hear about your challenges. Let's start a conversation.
  </Fragment>
</CallToAction>
</Layout>
