---
export const prerender = true;
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getLangFromUrl, useTranslations } from '~/i18n/translations';
import { sanityClient } from '~/sanity/client';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const metadata = {
  title: 'Producentric — Pensamento de produto. Disciplina de processo. Resultados reais.',
};
---

<Layout {metadata}>

  <Hero
    actions={[
      {
        variant: 'primary',
        text: t('cta.button'),
        href: '/pt-br/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Estratégia e execução para times que precisam
      <span class="text-accent dark:text-white"> avançar mais rápido.</span>
    </Fragment>
    <Fragment slot="subtitle">
      {t('hero.subtitle')}
    </Fragment>
  </Hero>

  <Features
    id="features"
    title={t('features.title')}
    subtitle={t('features.subtitle')}
    columns={3}
    classes={{ container: 'py-6 md:py-8 lg:py-10' }}
    items={[
      {
        title: t('nav.productManagement'),
        description: 'Trazemos o pensamento de produto para times que precisam de direção e momentum. Da descoberta e ideação até a validação com o cliente, ajudamos você a construir as coisas certas — e confirmar que estão funcionando.',
        icon: 'tabler:bulb',
      },
      {
        title: t('nav.projectManagement'),
        description: 'Mantemos iniciativas complexas nos trilhos. Responsabilidades claras, cronogramas realistas e a disciplina para entregar dentro do escopo, do orçamento e do prazo.',
        icon: 'tabler:checklist',
      },
      {
        title: t('nav.processImprovement'),
        description: 'Simplificamos como sua organização trabalha — de projetos compactos a grandes programas corporativos. Se você precisa de fluxos de trabalho mais enxutos ou de um framework ágil escalável como o SAFe, nós nos adaptamos à sua realidade.',
        icon: 'tabler:settings',
      },
    ]}
  />

  <Steps
    title={t('steps.title')}
    classes={{ container: 'py-6 md:py-8 lg:py-10' }}
    items={[
      {
        title: t('steps.understand.title'),
        description: t('steps.understand.description'),
        icon: 'tabler:ear',
      },
      {
        title: t('steps.define.title'),
        description: t('steps.define.description'),
        icon: 'tabler:map',
      },
      {
        title: t('steps.execute.title'),
        description: t('steps.execute.description'),
        icon: 'tabler:rocket',
      },
      {
        title: t('steps.validate.title'),
        description: t('steps.validate.description'),
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=987&q=80',
      alt: 'Time trabalhando junto',
    }}
  />

  <CallToAction
    classes={{ container: 'py-6 md:py-8 lg:py-10' }}
    actions={[
      {
        variant: 'primary',
        text: t('cta.button'),
        href: '/pt-br/contact',
      },
    ]}
  >
    <Fragment slot="title">{t('cta.title')}</Fragment>
    <Fragment slot="subtitle">{t('cta.subtitle')}</Fragment>
  </CallToAction>

</Layout>