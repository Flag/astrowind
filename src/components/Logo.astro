---
import { SITE } from 'astrowind:config';
---
<span class="flex items-center gap-2">
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="0" y="0" width="11" height="11" fill="#0F2D52" />
    <rect x="13" y="0" width="11" height="11" fill="#2F6BFF" />
    <rect x="0" y="13" width="11" height="11" fill="#0F2D52" />
    <rect x="13" y="13" width="11" height="11" fill="#0F2D52" />
  </svg>
  <span class="text-2xl md:text-xl font-bold text-gray-900 whitespace-nowrap">
    {SITE?.name}
  </span>
</span>